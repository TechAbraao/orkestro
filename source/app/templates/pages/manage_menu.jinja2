{% extends "layouts/administrative.jinja2" %}

{% block title %}
    Gerenciar Cardápios
{% endblock title %}

{% block sidenav %}
    {# Dynamic rendering from the backend #}
    {% include "partials/sidebar.jinja2" %}
    <script src="{{ url_for('static', filename='javascript/logout.js') }}" defer></script>
{% endblock sidenav %}

{% block dashboard %}
    <section class="w-full h-full bg-red-50 flex flex-col items-center justify-start">
    {# Modals #}
    {{ modals.modal_create_menu() }}
        <aside class="w-full h-[70px] bg-red-400">
            {% if strategy.get("profile")["hasMenu"] == False %}
                {{ buttons.button_create_menu(id_button="btn-open-modal-create-menu") }}
            {% endif %}
        </aside>
        <section class="w-full h-full bg-green-400">
            {% if strategy.get("profile")["hasMenu"] == False %}
                <h1>Nenhum cardápio encontrado.</h1>
            {% elif strategy.get("profile")["hasMenu"] == True %}
                <div id="menusContainer" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 p-6">
                    {# Os cards estão sendo populados aqui! #}
                </div>
            {% endif %}
        </section>
    </section>
    <script src="{{ url_for('static', filename='javascript/create_menu.js') }}" defer></script>
    <script src="{{ url_for('static', filename='javascript/menus_in_dashboard.js') }}" defer></script>
{% endblock dashboard %}

{% block navbar %}
    <aside class="w-full pl-10 text-lg font-extrabold">
        Gerenciar Cardápios | <span class="font-extralight">Tenha total controle sobre seus cardápios de forma rápida e fácil | </span> <span class="font-extralight" id="store-name-navbar">Company name</span>
    </aside>
{% endblock navbar %}

{% block footer %}
    <aside class="w-auto h-full">
        Orkestro © 2025 | versão 1.0.0
    </aside>
{% endblock footer %}