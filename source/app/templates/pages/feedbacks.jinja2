{% extends "layouts/administrative.jinja2" %}

{% block scripts %}
<script src="{{ url_for('static', filename='libs/jquery.mask.min.js') }}"></script>
<script src="{{ url_for('static', filename='libs/jquery.dataTables.min.js') }}"></script>
{% endblock scripts %}

{% block title %}
Feedbacks
{% endblock title %}

{% block sidenav %}
{% include "partials/sidebar.jinja2" %}
<script>
    const logoutURL = "{{ url_for('api.end_session_store') }}"
</script>
{% endblock sidenav %}

{% block dashboard %}
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/datatables.net-dt@2/css/dataTables.dataTables.min.css">

<section style="width:100%; padding: 1.5rem 0;">

    <div style="overflow-x:auto; border: 1px solid #e5e7eb; border-radius: 12px; background: #fff;">
        <table id="historicFeedbacksTable" class="display" style="width:100%">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Quem avaliou</th>
                    <th>Categorias</th>
                    <th>Nota</th>
                    <th>Descrição</th>
                    <th>Destino</th>
                    <th>Data</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>
</section>

<script>
    $(document).ready(function () {
        $('#historicFeedbacksTable').DataTable({
            ajax: { url: '/api/reviews/me', dataSrc: 'data' },
            columns: [
                {
                    data: 'id',
                    render: (data) => `<span style="font-family:monospace;font-size:11px;color:#9ca3af;background:#f3f4f6;padding:2px 6px;border-radius:6px">${String(data).slice(0, 8)}…</span>`
                },
                {
                    data: 'by',
                    render: (data) => `<span style="font-weight:500">${data}</span>`
                },
                {
                    data: 'category',
                    render: (data) => {
                        const cats = String(data).replace(/[{}"]/g, '').split(',');
                        return `<div style="display:flex;flex-wrap:wrap;gap:4px">${cats.map(c =>
                            `<span style="font-size:11px;padding:2px 8px;border-radius:999px;background:#f3f4f6;border:1px solid #e5e7eb;color:#6b7280">${c.trim()}</span>`
                        ).join('')}</div>`;
                    }
                },
                {
                    data: 'note',
                    render: (data) => `<div style="display:flex;align-items:center;gap:5px;font-weight:500"><span style="color:#f59e0b">★</span>${data}</div>`
                },
                {
                    data: 'description',
                    render: (data) => `<span style="color:#6b7280;font-size:13px">${data}</span>`
                },
                {
                    data: 'to',
                    render: (data) => `<span style="font-size:11px;padding:3px 8px;border-radius:6px;background:#eff6ff;color:#1d4ed8;border:1px solid #bfdbfe">${data}</span>`
                },
                {
                    data: 'created',
                    render: (data) => new Date(data).toLocaleDateString('pt-BR', { day: '2-digit', month: '2-digit', year: 'numeric' })
                }
            ],
            responsive: true,
            pageLength: 5,
            autoWidth: false,
            language: { url: '//cdn.datatables.net/plug-ins/1.13.7/i18n/pt-BR.json' }
        });
    });
</script>
{% endblock dashboard %}

{% block navbar %}
<aside class="w-full pl-10 text-lg font-extrabold flex items-center justify-between">
    <div class="w-1/2">
        <p>Feedback dos Clientes | <span class="font-extralight">Todos os feedbacks | </span>
            <span class="font-extralight" id="store-name-navbar"></span>
        </p>
    </div>
    <div class="w-1/2 flex items-center justify-end ">
        <a href="{{ url_for('vws.views_profile_dashboard') }}"
            class="flex items-center gap-3 px-3 py-2 rounded-lg text-white/60 hover:text-white hover:bg-white/5 transition-all duration-200 mr-5">
            <div
                class="w-8 h-8 flex items-center justify-center rounded-md bg-white/5 group-hover:bg-indigo-500/20 transition-colors duration-200">
                <img src="{{ url_for('static', filename='icons/profile.png') }}" alt="Perfil"
                    class="w-4 h-4 brightness-0 invert opacity-60 group-hover:opacity-100 transition-opacity duration-200">
            </div>
            <span class="text-[14px] font-medium sidebar-text tracking-wide text-white">Perfil</span>
        </a>
    </div>
</aside>
{% endblock navbar %}

