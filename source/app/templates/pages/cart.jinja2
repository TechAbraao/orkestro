{% extends "layouts/default.jinja2" %}

{% block sidenav %}
<section class="bg-gray-900 h-full flex items-center justify-start">
    <a href="/menus/{{ strategy['menu_slug'] }}/{{ strategy['return_id'] }}" class="p-3 ml-5 bg-green-200 rounded-2xl">
        VOLTAR
    </a>
</section>
{% endblock sidenav %}

{% block content %}
    <section class="bg-gray-100 py-10 w-full h-full">
        <div class="max-w-4xl mx-auto bg-white rounded-2xl shadow p-8">
            <h1 class="text-3xl font-semibold mb-6 flex items-center gap-3">
                <img src="{{ url_for('static', filename='icons/cart.png') }}" class="w-10 h-10">
                Seu Carrinho
            </h1>
            <div id="cartItems" class="space-y-5">
                <div class="flex items-center justify-between bg-gray-50 p-4 rounded-xl border shadow-sm">
                    <div class="flex items-center gap-4">
                        <img src="{{ url_for('static', filename='icons/product.png') }}"
                             class="w-14 h-14 rounded-lg bg-gray-200">

                        <div>
                            <h2 class="text-lg font-semibold">Nome do Produto</h2>
                            <p class="text-gray-600 text-sm">Qtd: 2</p>
                        </div>
                    </div>
                    <div class="text-right font-semibold text-lg text-green-600">
                        R$ 39,90
                    </div>
                </div>
            </div>
            <hr class="my-8">
            <div class="flex items-center justify-between mb-8">
                <span class="text-xl font-semibold">Total:</span>
                <span id="cartTotal" class="text-2xl font-bold text-green-600">R$ 0,00</span>
            </div>
            <div class="flex justify-between">
                <button class="btn-clear-cart bg-red-500 hover:bg-red-600 text-white px-6 py-3 rounded-xl font-medium shadow">
                    Limpar Carrinho
                </button>

                <button class="btn-finish-order bg-blue-600 hover:bg-blue-700 text-white px-6 py-3 rounded-xl font-medium shadow">
                    Finalizar Pedido
                </button>
            </div>
        </div>
    </section>



    <script>
        const menuSlug = "{{ strategy['menu_slug'] }}"
    </script>
{% endblock content %}

{% block footer %}
    <section class="bg-gray-900 h-[128px] w-full">
        <h1>AAAA{{ strategy['menu_slug'] }}</h1>
        <h2>RETURN ID: {{ strategy['return_id'] }} </h2>
    </section>
{% endblock footer %}