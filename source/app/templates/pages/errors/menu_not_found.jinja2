{% extends "layouts/default.jinja2" %}

{% block title %}
    Não encontrado
{% endblock title %}

{% block content %}
<div class="min-h-[65vh] flex items-center justify-center px-4">
    <div class="max-w-md w-full text-center bg-white rounded-3xl shadow-xl p-8 sm:p-10">

        <div class="flex justify-center mb-6">
            <div class="w-16 h-16 flex items-center justify-center rounded-full
                        bg-gradient-to-br from-red-100 to-red-200 text-red-600 shadow-sm">
                <svg xmlns="http://www.w3.org/2000/svg"
                     class="h-8 w-8"
                     fill="none"
                     viewBox="0 0 24 24"
                     stroke="currentColor">
                    <path stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M12 9v2m0 4h.01M5.07 19h13.86c1.54 0 2.5-1.67 1.73-3L13.73 4c-.77-1.33-2.69-1.33-3.46 0L3.34 16c-.77 1.33.19 3 1.73 3z"/>
                </svg>
            </div>
        </div>

        <h1 class="text-2xl sm:text-3xl font-extrabold text-gray-900 mb-3">
            Menu não encontrado
        </h1>

        <p class="text-gray-600 mb-6 leading-relaxed">
            O cardápio que você tentou acessar não existe ou não está mais disponível.
        </p>

        {% if suggestion %}
        <div class="bg-gray-50 border border-gray-200 rounded-xl p-4 mb-6 flex items-center flex-col ">
            <h2 class="text-sm font-semibold text-gray-700 mb-1">
                Talvez você esteja procurando por:
            </h2>
            <p class="text-lg font-medium text-gray-900 bg-green-300 rounded-full pl-3 pr-3">
                {{ suggestion.replace("-", " ").title() }}
            </p>
        </div>

        <a href="/menus/{{ suggestion }}"
           class="inline-flex items-center justify-center w-full
                  px-6 py-3 rounded-xl text-sm font-semibold
                  text-white bg-gray-900 hover:bg-gray-800
                  transition focus:outline-none focus:ring-2 focus:ring-gray-400">
            Ver cardápio sugerido
        </a>
        {% endif %}
    </div>
</div>
{% endblock content %}

