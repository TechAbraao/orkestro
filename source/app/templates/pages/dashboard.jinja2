<script>
    const byName = "{{ strategy.get("profile")["name"] }}"
    // window.alert(byName)
</script>
<script src="{{ url_for('static', filename='javascript/analysisOverview.js') }}" defer></script>
<script src="{{ url_for('static', filename='javascript/suggestions.js') }}" defer></script>
<script>
    const doc = new jspdf.jsPDF();
    const btnGenerateReport = $(".btn-generate-report");

    btnGenerateReport.on("click", async function () {
        const res = await fetch("/api/analysis/sales-per-week");
        const dataSalesPerWeek = await res.json();

        const dias = [
            "Segunda-feira",
            "Terça-feira",
            "Quarta-feira",
            "Quinta-feira",
            "Sexta-feira",
            "Sábado",
            "Domingo"
        ];

        const quantidades = dataSalesPerWeek.data;
        const totais = dataSalesPerWeek.total;

        const linhas = dias.map((dia, index) => [
            dia,
            quantidades[index],
            `R$ ${totais[index].toFixed(2)}`
        ]);

        doc.setFontSize(32);
        doc.text("Relatório de Vendas por Semana", 10, 15);

        doc.autoTable({
            startY: 25,
            head: [["Dia da Semana", "Quantidade de Pedidos", "Total Vendido em R$"]],
            body: linhas
        });

        const pageCount = doc.internal.getNumberOfPages();
        doc.setFontSize(10);
        doc.text(`Gerado em ${new Date().toLocaleDateString()}`, 10, 290);
        doc.text(`Página ${pageCount}`, 180, 290);

        doc.save(`relatorio-${new Date().toLocaleDateString()}.pdf`);
    });
</script>
