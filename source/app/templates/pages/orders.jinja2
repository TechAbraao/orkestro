{% extends "layouts/administrative.jinja2" %}

{% block title %}
    Pedidos
{% endblock title %}

{% block sidenav %}
    {# Dynamic rendering from the backend #}
    {% include "partials/sidebar.jinja2" %}
    <script>
        const logoutURL = "{{ url_for('sign_in_auth.end_session_store') }}"
    </script>
    <script src="{{ url_for('static', filename='javascript/toggle_sidenav.js') }}" defer></script>
    <script src="{{ url_for('static', filename='javascript/logout.js') }}" defer></script>
{% endblock sidenav %}

{% block dashboard %}
    <section class="w-full h-full bg-red-50 flex flex-col items-center justify-start p-10">
        <h2 class="text-2xl font-bold mb-6">Orders Dashboard</h2>
        <ul id="orders-list" class="w-full max-w-4xl bg-white rounded-xl shadow-md p-6 space-y-3">
            {# Orders will be entered here #}
        </ul>
    </section>

    <script src="https://cdn.socket.io/4.7.2/socket.io.min.js"></script>
    <script src="{{ url_for('static', filename='javascript/websocket_orders.js') }}" defer></script>
{% endblock dashboard %}

{% block navbar %}
    <aside class="w-full pl-10 text-lg font-extrabold">
        Pedidos | <span class="font-extralight">Seja bem-vindo novamente,</span> <span class="font-extralight"
                                                                          id="store-name-navbar">Company name</span>
    </aside>
{% endblock navbar %}

{% block footer %}
    <aside class="w-auto h-full">
        Orkestro © 2025 | version 1.0.0
    </aside>
{% endblock footer %}