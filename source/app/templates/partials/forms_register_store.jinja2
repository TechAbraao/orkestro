<form action="#" method="post" autocomplete="on" aria-labelledby="form-title"
      class="w-1/3 mx-auto mt-10 bg-white shadow-lg rounded-xl p-8 space-y-6">
    <fieldset>
        <legend id="form-title" class="sr-only">Registration form</legend>
        {# Field StoreName #}
        <div class="flex flex-col space-y-2">
            <label for="storeName" class="text-sm font-medium text-gray-700">Store Name</label>
            <input id="storeName" name="storeName" type="text" required autocomplete="storeName"
                   placeholder="Your Store Name"
                   class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-red-400 focus:outline-none"/>
        </div>
        {# Field Email #}
        <div class="flex flex-col space-y-2">
            <label for="email" class="text-sm font-medium text-gray-700 pt-2">Email</label>
            <input id="email" name="email" type="email" required autocomplete="email" placeholder="you@example.com"
                   class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-red-400 focus:outline-none"/>
        </div>
        {# Field Password #}
        <div class="flex flex-col space-y-2">
            <label for="password" class="text-sm font-medium text-gray-700 pt-2">Password</label>
            <input id="password" name="password" type="password" required minlength="8" autocomplete="new-password"
                   aria-describedby="passwordHelp" placeholder="At least 8 characters"
                   class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-red-400 focus:outline-none"/>
            <small id="passwordHelp" class="text-xs text-gray-500">Minimum 8 characters.</small>
        </div>
        {# Field Telephone #}
        <div class="flex flex-col space-y-2">
            <label for="telephone" class="text-sm font-medium text-gray-700">Telephone</label>
            <input id="telephone" name="telephone" type="tel" required
                   pattern="\+?[0-9\s\-\(\)]{7,20}"
                   title="Enter a valid phone number (digits, spaces, +, -, parentheses)."
                   autocomplete="tel" placeholder="+1 (555) 555-0123"
                   class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-red-400 focus:outline-none"/>
        </div>
        <div>
            <button type="submit"
                    class="w-full bg-red-500 text-white py-2 rounded-lg font-semibold hover:bg-red-600 transition mt-5">
                Create account
            </button>

            {# Alerts #}
            <aside class="mt-1 flex items-center justify-center">
                {{ alerts.alert_forms(
                type="error",
                alert_base_class="alert_base_register_error",
                alert_message_class="alert_register_store_error"
                ) }}
            </aside>

            <aside class="mt-1 flex items-center justify-center">
                {{ alerts.alert_forms(
                type="success",
                alert_base_class="alert_base_register_success",
                alert_message_class="alert_register_store_success"
                ) }}
            </aside>

        </div>
    </fieldset>
</form>
