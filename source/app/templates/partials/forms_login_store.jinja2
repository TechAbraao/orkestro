<form action="#" method="" autocomplete="on" aria-labelledby="form-title"
      class="w-1/3 mx-auto mt-10 bg-white shadow-sm border-2
       border-solid border-gray-200 rounded-xl p-12 space-y-6">
    <fieldset>
        <legend id="form-title" class="sr-only">Login form</legend>

        {# Field Email #}
        <div class="flex flex-col space-y-2">
            <label for="email" class="text-sm font-medium text-gray-700">E-mail</label>
            <input id="email" name="email" type="email" required autofocus
                   title="Coloque seu e-mail comercial."
                   autocomplete="email" placeholder="Digite seu e-mail"
                   class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-red-400 focus:outline-none"/>
        </div>

        {# Field Password #}
        <div class="flex flex-col space-y-2">
            <label for="password" class="text-sm font-medium text-gray-700 pt-2">Senha</label>
            <input id="password" name="password" type="password" required minlength="6" autocomplete="current-password"
                   title="Digite sua senha."
                   placeholder="Sua senha"
                   class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-red-400 focus:outline-none"/>
        </div>

        {# Button + or Create your Account Now #}
        <div class="flex flex-center flex-col">

            {# Alerts - WARNING IN LOGIN #}
            <aside class="mt-1 flex items-center justify-center">
                {{ alerts.alert_forms(
                type="warning",
                alert_base_class="alert_base_login_warning",
                alert_message_class="alert_login_store_warning"
                ) }}
            </aside>


            {# Alerts - ERROR IN LOGIN #}
            <aside class="mt-1 flex items-center justify-center">
                {{ alerts.alert_forms(
                type="error",
                alert_base_class="alert_base_login_error",
                alert_message_class="alert_login_store_error"
                ) }}
            </aside>

            {# Alerts - SUCCESS IN LOGIN #}
            <aside class="mt-1 flex items-center justify-center">
                {{ alerts.alert_forms(
                type="success",
                alert_base_class="alert_base_login_success",
                alert_message_class="alert_login_store_success"
                ) }}
            </aside>

            <button type="submit"
                    class="w-full bg-red-500 text-white py-2 rounded-lg font-semibold hover:bg-red-600 transition mt-2">
                Entrar
            </button>
            <span class="text-center mt-3    cursor-pointer">
                <a href="{{ url_for("authorizations_frontend.views_register") }}">Ou crie agora sua conta comercial </a>
            </span>
        </div>
    </fieldset>
</form>
