    <div class="bg-white rounded-2xl shadow-lg max-w-md w-full p-6">
        {# Headers #}
        <div class="w-full h-[130px] flex items-center justify-center">
            <aside class="w-[100px] h-[100px] bg-gray-200 flex items-center justify-center rounded-full">
                <img src="{{ url_for('static', filename='icons/exit-2.png') }}" class="w-[45px] h-[45px]" />
