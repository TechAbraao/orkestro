{% macro modal_menu_status() %}
<div id="modalMenuStatus" class="fixed inset-0 bg-black/40 backdrop-blur-[1.5px] flex items-center justify-center hidden z-50">
    <div class="bg-white rounded-lg shadow-lg max-w-md w-full p-6">

        <h2 class="text-xl font-bold text-gray-800 mb-4">Status do Cardápio</h2>

        {# Switch ON/OFF #}
        <div class="flex items-center space-x-3">
            <button id="menuToggle" type="button"
                class="relative inline-flex h-6 w-11 items-center rounded-full bg-gray-300 transition-colors focus:outline-none"
                role="switch" aria-checked="false">
                <span class="inline-block h-4 w-4 transform rounded-full bg-white transition-transform"></span>
            </button>

            <span id="menuStatusText" class="text-red-600 font-medium">
                Cardápio Desativado
            </span>
        </div>

        <div>
            {{ alerts.alert_forms(
            type="info", alert_base_class="notify-status-changed",
            alert_message_class="notify-status-changed-msg") }}
        </div>

        <div class="flex flex-col gap-1 mt-6">
            <button id="btnConfirmStatus" class="flex items-center justify-center w-full h-[60px]
            bg-gradient-to-r from-indigo-500 via-indigo-600 to-indigo-700
            hover:from-indigo-600 hover:to-indigo-800
            text-white font-semibold
            rounded-2xl shadow-md hover:shadow-lg
            transition-all duration-200
            active:scale-95">
                Salvar
            </button>
            <button id="btnCancelStatus"
                class="flex items-center justify-center w-full h-[60px]
            bg-white border border-gray-300
            hover:bg-gray-100
            text-gray-700 font-semibold
            rounded-2xl shadow-sm hover:shadow
            transition-all duration-200
            active:scale-95">
                Fechar
            </button>
        </div>
    </div>
</div>
<script>
    document.addEventListener("DOMContentLoaded", () => {
        const toggleBtn = document.getElementById("menuToggle");
        const statusText = document.getElementById("menuStatusText");
        const notifyStatusChanged = $(".notify-status-changed")
        const notifyStatusChangedMsg = $(".notify-status-changed-msg")
        const menuStatusSidebar = $(".menu-status-in-sidebar")

        $.ajax({
            url: `/api/menus/${menuId}/status`,
            method: "GET",
            success: function (response) {
                const statusMenu = Boolean(response.data);
                toggleBtn.setAttribute("aria-checked", statusMenu);

                if (statusMenu) {
                    toggleBtn.classList.add("bg-green-500");
                    toggleBtn.querySelector("span").classList.add("translate-x-5");
                    statusText.textContent = "Cardápio Ativado";
                    statusText.classList.add("text-green-600");
                } else {
                    toggleBtn.classList.add("bg-gray-300");
                    toggleBtn.querySelector("span").classList.add("translate-x-0");
                    statusText.textContent = "Cardápio Desativado";
                    statusText.classList.add("text-red-600");
                }

                toggleBtn.addEventListener("click", () => {
                    const isActive = toggleBtn.getAttribute("aria-checked") === "true";

                    if (isActive) {
                        toggleBtn.setAttribute("aria-checked", "false");
                        toggleBtn.classList.remove("bg-green-500");
                        toggleBtn.classList.add("bg-gray-300");
                        toggleBtn.querySelector("span").classList.remove("translate-x-5");
                        toggleBtn.querySelector("span").classList.add("translate-x-0");
                        statusText.textContent = "Cardápio Desativado";
                        statusText.classList.remove("text-green-600");
                        statusText.classList.add("text-red-600");
                        // menuStatusSidebar.text("Fechado");
                        // menuStatusSidebar.addClass("text-[16px] font-bold text-center bg-red-300 text-red-700 pl-2 pr-2 mt-2 w-[90%] rounded-full");
                    } else {
                        toggleBtn.setAttribute("aria-checked", "true");
                        toggleBtn.classList.remove("bg-gray-300");
                        toggleBtn.classList.add("bg-green-500");
                        toggleBtn.querySelector("span").classList.remove("translate-x-0");
                        toggleBtn.querySelector("span").classList.add("translate-x-5");
                        statusText.textContent = "Cardápio Ativado";
                        statusText.classList.remove("text-red-600");
                        statusText.classList.add("text-green-600");
                        // menuStatusSidebar.text("Aberto");
                        // menuStatusSidebar.addClass("text-[16px] font-bold text-center bg-green-300 text-green-800 pl-2 pr-2 mt-2 w-[90%] rounded-full");
                    }
                });
            },
            error: function (xhr) {
                // console.error("Error ON/OFF:", xhr.responseText);
            }
        });

        document.getElementById("btnCancelStatus").addEventListener("click", () => {
            document.getElementById("modalMenuStatus").classList.add("hidden");
        });

        document.getElementById("btnConfirmStatus").addEventListener("click", () => {
            const isActive = toggleBtn.getAttribute("aria-checked") === "true";
            console.log(isActive)
            $.ajax({
                url: `/api/menus/${menuId}/status`,
                method: "PATCH",
                success: function (response) {
                    // console.log("Response ON/OFF:", response);
                    notifyStatusChanged.removeClass("hidden")
                    notifyStatusChangedMsg.text("Cardápio atualizado para: " + (isActive ? "ativado" : "desativado"))

                    menuStatusSidebar.removeClass("bg-green-300 text-green-800 bg-red-300 text-red-700");
                    if (isActive) {
                        menuStatusSidebar.text("Aberto");
                        menuStatusSidebar.addClass("bg-green-300 text-green-800");
                    } else {
                        menuStatusSidebar.text("Fechado");
                        menuStatusSidebar.addClass("bg-red-300 text-red-700");
                    }

                    setTimeout(() => {
                        notifyStatusChanged.addClass("hidden")
                    }, 2500)
                },
                error: function (xhr) {
                    // console.error("Error ON/OFF:", xhr.responseText);
                }
            });

        });
    });
</script>
{% endmacro %}

{% macro opening_hours() %}
<div id="modalOpeningHours" class="fixed inset-0 bg-black/40 backdrop-blur-[1.5px] flex items-center justify-center hidden z-50">
    <div class="bg-white w-full max-w-lg rounded-2xl shadow-lg p-6">
        <h2 class="text-2xl font-semibold text-gray-800 mb-4 text-center">Horários de Funcionamento</h2>
        <form id="openingHoursForm" class="space-y-3">
            {% set days = ["Segunda", "Terca", "Quarta", "Quinta", "Sexta", "Sabado", "Domingo"] %}
            {% for day in days %}
            <div class="flex items-center justify-between gap-3 border-b border-gray-200 pb-2">
                <span class="w-24 font-medium text-gray-700">{{ day }}</span>
                <div class="flex gap-2">
                    <input id="{{ day | lower }}_open" type="time" name="{{ day|lower }}_open"
                        class="border rounded-lg p-2 text-sm focus:ring-2 focus:ring-blue-500 focus:outline-none" />
                    <span class="text-gray-500">às</span>
                    <input id="{{ day | lower }}_close" type="time" name="{{ day|lower }}_close"
                        class="border rounded-lg p-2 text-sm focus:ring-2 focus:ring-blue-500 focus:outline-none" />
                </div>
            </div>
            {% endfor %}
        </form>

        <div class="flex flex-col end mt-6 gap-3">
            <button type="submit" form="openingHoursForm"
                class="px-4 py-2 rounded-lg bg-blue-600 text-white hover:bg-blue-700 transition">
                Confirmar
            </button>
            <button type="submit" id="restoreHoursBtn"
                class="px-4 py-2 rounded-lg bg-red-600 text-white hover:bg-red-700 transition">
                Restaurar
            </button>
            <button type="button" id="cancelModalBtn"
                class="px-4 py-2 rounded-lg border border-gray-300 hover:bg-gray-100 transition">
                Fechar
            </button>
        </div>
    </div>
</div>
<script>
    $(document).ready(function () {
        const modal = document.getElementById('modalOpeningHours');
        const cancelBtn = document.getElementById('cancelModalBtn');

        function openOpeningHoursModal() {
            modal.classList.remove('hidden');
        }

        function closeOpeningHoursModal() {
            modal.classList.add('hidden');
        }

        cancelBtn.addEventListener('click', closeOpeningHoursModal);

        document.getElementById('openingHoursForm').addEventListener('submit', function (e) {
            e.preventDefault();
            const data = new FormData(this);
            const entries = Object.fromEntries(data.entries());
            console.log(entries);
            closeOpeningHoursModal();
        });
    })
</script>
{% endmacro %}

{% macro modal_add_product() %}
<div id="modalAddProduct"
    class="fixed inset-0 bg-black/40 backdrop-blur-[1.5px] flex items-center justify-center hidden z-50">
    <div class="bg-white rounded-lg shadow-lg max-w-md w-full p-6 relative">
        <button id="closeModalAddProduct" class="absolute top-3 right-3 text-gray-500 hover:text-gray-700 font-bold"
            onclick="document.getElementById('modalAddProduct').classList.add('hidden')">
            &times;
        </button>

        <h2 class="text-xl font-bold text-gray-800 mb-4">Adicionar Produto</h2>

        <div class="flex justify-between items-center border-b mb-3"></div>

        <form id="formAddProduct" class="space-y-4">
            <div>
                <label for="productName" class="block text-gray-700 font-medium mb-1">Nome do Produto <small id="" class="text-[15px] text-red-500 pb-2">*</small></label>
                <input type="text" id="productName" name="name"
                    class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500"
                    placeholder="Digite o nome do produto" required />
            </div>

            <div>
                <label for="productPrice" class="block text-gray-700 font-medium mb-1">Preço (R$) <small id="" class="text-[15px] text-red-500 pb-2">*</small></label>
                <input type="number" step="0.01" id="productPrice" name="price"
                    class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500"
                    placeholder="0.00" required />
            </div>

            <div>
                <label for="productDescription" class="block text-gray-700 font-medium mb-1">Descrição</label>
                <textarea id="productDescription" name="description" rows="3"
                    class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500"
                    placeholder="Digite a descrição do produto" required></textarea>
            </div>

            <div class="flex justify-between items-center border-b mb-1"></div>

            <div class="flex flex-col justify-start gap-1 mt-2">

                <button id="btn-confirm-add-product" type="submit" class="flex items-center justify-center w-full h-[60px]
            bg-gradient-to-r from-indigo-500 via-indigo-600 to-indigo-700
            hover:from-indigo-600 hover:to-indigo-800
            text-white font-semibold
            rounded-2xl shadow-md hover:shadow-lg
            transition-all duration-200
            active:scale-95">
                                Confirmar
                </button>

                <button type="button" id="cancelAddProduct"
                    class="flex items-center justify-center w-full h-[60px]
            bg-white border border-gray-300
            hover:bg-gray-100
            text-gray-700 font-semibold
            rounded-2xl shadow-sm hover:shadow
            transition-all duration-200
            active:scale-95"
                    onclick="document.getElementById('modalAddProduct').classList.add('hidden')">
                    Cancelar
                </button>
            </div>
        </form>
    </div>
</div>
{% endmacro %}

