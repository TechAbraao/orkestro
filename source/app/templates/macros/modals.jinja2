{% macro modal_logout(header_text="", description_text="") %}
    <div id="logoutModal" class="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center hidden z-50">
        <div class="bg-white rounded-lg shadow-lg max-w-md w-full p-6">
            {# Headers #}
            <div class="flex justify-between items-center mb-4">
                <h3 class="text-lg font-semibold text-gray-800">{{ header_text }}</h3>
                <button onclick="document.getElementById('logoutModal').classList.add('hidden')"
                        class="text-gray-400 hover:text-gray-600">&times;
                </button>
            </div>

            {# Content #}
            <p class="text-gray-600 mb-6">
                {{ description_text }}
            </p>

            {# Buttons #}
            <div class="flex justify-end gap-3">
                <button
                        onclick="document.getElementById('logoutModal').classList.add('hidden')"
                        class="px-4 py-2 rounded bg-gray-200 hover:bg-gray-300 text-gray-700 transition-colors">
                    Cancel
                </button>
                <form method="#">
                    <button
                            type="submit"
                            id="btn-confirm-logout"
                            class="px-4 py-2 rounded bg-red-600 hover:bg-red-700 text-white transition-colors">
                        Confirm Logout
                    </button>
                </form>
            </div>
        </div>
    </div>
{% endmacro %}

{% macro modal_about_orkestro() %}
    <div id="aboutOrkestroModal"
         class="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center hidden z-50">
        <div class="bg-white rounded-2xl shadow-lg max-w-lg w-full p-6 relative">

            <button onclick="document.getElementById('aboutOrkestroModal').classList.add('hidden')"
                    class="absolute top-3 right-3 text-gray-500 hover:text-gray-700">
                ✕
            </button>

            <h2 class="text-2xl font-bold text-gray-800 mb-4">
                Sobre o Orkestro
             <small id="versionProjectOrkestro" class="text-xs text-gray-500">versão 1.0.0</small>
            </h2>
            <p class="text-gray-600 leading-relaxed mb-4">
                O <strong>Orkestro</strong> é um projeto desenvolvido para simplificar e organizar
                processos de forma acessível e funcional. Nossa missão é fornecer uma
                plataforma que atue como um <em>MVP</em> inicial, mas com base sólida para
                futuras evoluções.
            </p>

            <ul class="list-disc pl-5 text-gray-600 space-y-1 mb-4">
                <li>Foco em acessibilidade e usabilidade</li>
                <li>Desenvolvimento ágil e iterativo</li>
                <li>Baseado em tecnologias modernas</li>
            </ul>

            <p class="text-gray-600 leading-relaxed">
                Essa é apenas a primeira versão, mas acreditamos que o Orkestro pode
                evoluir para se tornar uma solução robusta e completa.
            </p>

            <div class="mt-6 text-right">
                <button onclick="document.getElementById('aboutOrkestroModal').classList.add('hidden')"
                        class="px-4 py-2 bg-blue-600 text-white rounded-xl hover:bg-blue-700 transition">
                    Fechar
                </button>
            </div>
        </div>
    </div>
{% endmacro %}

{% macro modal_create_menu() %}
<div id="modalCreateMenuModal"
     class="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center hidden z-50">

  {# Content #}
  <div class="bg-white rounded-xl shadow-lg w-full max-w-md p-6 relative">

    <button type="button"
            onclick="document.getElementById('modalCreateMenuModal').classList.add('hidden')"
            class="absolute top-3 right-3 text-gray-400 hover:text-gray-600 focus:outline-none">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none"
           viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>

    {# Title #}
    <h2 class="text-lg font-semibold text-gray-900 mb-4">
      Criar Novo Cardápio
    </h2>

    {# Forms #}
    <form method="POST" action="/menus/create" class="space-y-4">
      <div>
        <label for="menu_name" class="block text-sm font-medium text-gray-700">
          Nome
        </label>
        <input type="text" id="menu_name" name="name" required
               class="mt-1 block w-full rounded-lg border-gray-300 shadow-sm
                      focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm"/>
      </div>

      {# Description #}
      <div>
        <label for="menu_description" class="block text-sm font-medium text-gray-700">
          Descrição
        </label>
        <textarea id="menu_description" name="description" rows="3"
                  class="mt-1 block w-full rounded-lg border-gray-300 shadow-sm
                         focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm"></textarea>
      </div>

        {# Actions #}
      <div class="flex justify-end gap-3">
        <button type="button"
                onclick="document.getElementById('modalCreateMenuModal').classList.add('hidden')"
                class="px-4 py-2 rounded-lg border border-gray-300 text-gray-700
                       hover:bg-gray-50 focus:outline-none focus:ring-2
                       focus:ring-indigo-500">
          Cancelar
        </button>
        <button type="submit"
                id="btn-create-menu"
                class="px-4 py-2 rounded-lg bg-indigo-600 text-white
                       hover:bg-indigo-700 focus:outline-none focus:ring-2
                       focus:ring-indigo-500">
          Criar
        </button>
      </div>
    </form>
  </div>
</div>
{% endmacro %}
