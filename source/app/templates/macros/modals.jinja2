{% macro modal_about_store(modal_id="modalAboutStore", menuId="") %}
<div id="{{ modal_id }}" class="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center hidden z-50">
    <div class="bg-white rounded-2xl shadow-xl w-full max-w-lg p-6 relative">
        <button onclick="document.getElementById('{{ modal_id }}').classList.add('hidden')"
            class="absolute top-4 right-4 text-gray-500 hover:text-gray-700">
            &times;
        </button>

        <section>
            <h2>Sobre</h2>
            <p class="text-sm pb-2">Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor
                incididunt ut labore et
                dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut
                aliquip
                ex ea commodo consequat. Duis aute irure dolor in reprehenderit in voluptate velit esse cillum
                dolore eu
                fugiat nulla pariatur. Excepteur sint occaecat cupidatat non proident, sunt in culpa qui officia
                deserunt mollit anim id est laborum.</p>
        </section>

        <section>
            <h2 class="text-xl font-bold mb-4">Horários de Funcionamento</h2>
            <ul id="hours-container-list" class="space-y-2 text-gray-800">
                {# Horários serão inseridos aqui dinamicamente via JS #}
            </ul>
        </section>
    </div>
</div>
<script>
    $(document).ready(function () {
        function getAllHoursInMenu(menu_id) {
            $.ajax({
                url: `/api/menus/${menu_id}/opening-hours`,
                method: "GET",
                success: function (res) {
                    const hours = res.data;
                    const list = $("#hours-container-list");
                    list.empty();

                    if (!hours || hours.length === 0) {
                        list.append('<li class="text-red-500 italic">Nenhum horário cadastrado.</li>');
                        return;
                    }

                    const orderedDays = ["monday", "tuesday", "wednesday", "thursday", "friday", "saturday", "sunday"];
                    const daysInPortuguese = {
                        monday: "Segunda-feira",
                        tuesday: "Terça-feira",
                        wednesday: "Quarta-feira",
                        thursday: "Quinta-feira",
                        friday: "Sexta-feira",
                        saturday: "Sábado",
                        sunday: "Domingo"
                    };

                    const sortedHours = hours.sort((a, b) => orderedDays.indexOf(a.day) - orderedDays.indexOf(b.day));

                    sortedHours.forEach(hour => {
                        const open = hour.open || "--:--";
                        const close = hour.close || "--:--";
                        const dayName = daysInPortuguese[hour.day] || hour.day;

                        const li = `
                        <li class="flex justify-between items-center bg-gray-100 p-2 rounded-md">
                            <span class="font-medium">${dayName}</span>
                            <span class="text-sm text-gray-600">${open} - ${close}</span>
                        </li>
                    `;
                        list.append(li);
                    });
                },
                error: function (xhr) {
                    const responseError = xhr.responseText;
                    alert("Erro ao carregar horários: " + responseError);
                }
            });
        }
        getAllHoursInMenu("{{ menuId }}");
    });
</script>
{% endmacro %}


{% macro modal_order_details(modal_id="") %}
<div id="{{ modal_id }}" class="fixed inset-0 bg-black bg-opacity-50 hidden z-50 flex items-center justify-center">
    <div class="bg-white rounded-2xl shadow-xl p-6 w-[750px] relative">

        <button class="absolute top-3 right-3 text-gray-600 hover:text-gray-800" onclick="closeModal('{{ modal_id }}')">
            ✕
        </button>

        <h2 class="text-xl font-semibold text-gray-800 mb-4">Detalhes do Pedido</h2>

        <section class="mb-4 border-b pb-4">
            <h3 class="text-lg font-medium text-gray-700 mb-2">Informações do Cliente</h3>
            <p class="text-lg"><span class="font-semibold">Nome:</span> <span id="{{ modal_id }}_client_name"></span>
            </p>
            <p class="text-lg"><span class="font-semibold">Telefone:</span> +<span
                    id="{{ modal_id }}_client_phone"></span></p>
            <p class="text-lg"><span class="font-semibold">Endereço:</span> <span
                    id="{{ modal_id }}_client_address"></span></p>
            <p class="text-lg"><span class="font-semibold">Número:</span> <span
                    id="{{ modal_id }}_client_number"></span></p>
            <p class="text-lg"><span class="font-semibold">Método de Pagamento:</span> <span
                    id="{{ modal_id }}_client_payment"></span> Crédito/Débito/Pix/Dinheiro</p>
        </section>

        <section class="mb-6">
            <h3 class="text-lg font-medium text-gray-700 mb-2">Items do Pedido</h3>
            <ul id="{{ modal_id }}_order_items" class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-2 gap-3
                flex items-center justify-center">
                {# Aqui será preenchido via JS #}
            </ul>
        </section>

        <div class="flex items-center text-lg font-semibold text-gray-800">
            <span>Total: R$</span>
            <span id="{{ modal_id }}_order_total" class="pl-1"></span>
        </div>

    </div>
</div>
<script>
    $(document).ready(function () {
        window.openModal = function (id) {
            document.getElementById(id).classList.remove("hidden");

        }
        window.closeModal = function (id) {
            document.getElementById(id).classList.add("hidden");
        }
    });
</script>
{% endmacro %}

