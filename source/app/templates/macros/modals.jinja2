{% macro modal_create_category() %}
<div id="modalCreateCategory" class="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center hidden z-50">
    <div class="bg-white rounded-lg w-11/12 max-w-md p-6 relative shadow-lg">
        {# Botão Fechar #}
        <button id="closeModal" class="absolute top-3 right-3 text-gray-500 hover:text-gray-800 font-bold text-xl">&times;</button>

        <h2 class="text-2xl font-bold mb-4">Criar Nova Categoria</h2>


        <form id="formCreateCategory" class="flex flex-col gap-4">
            <div>
                <label for="categoryName" class="block text-gray-700 font-semibold mb-1">Nome da Categoria</label>
                <input type="text" id="categoryName" name="name" class="w-full border border-gray-300 rounded px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500" required>
            </div>
            <div>
                <label for="categoryDescription" class="block text-gray-700 font-semibold mb-1">Descrição</label>
                <textarea id="categoryDescription" name="description" class="w-full border border-gray-300 rounded px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500" rows="3" required></textarea>
            </div>

            {# Botões #}
            <div class="flex justify-end gap-2 mt-4">
                <button type="button" id="cancelCreateCategory" class="px-4 py-2 rounded bg-gray-300 hover:bg-gray-400 text-gray-800 font-semibold">
                    Cancelar
                </button>
                <button id="btn-confirm-create-category" type="submit" class="px-4 py-2 rounded bg-blue-600 hover:bg-blue-700 text-white font-semibold">
                    Confirmar
                </button>
            </div>
        </form>
    </div>
</div>
{% endmacro %}

