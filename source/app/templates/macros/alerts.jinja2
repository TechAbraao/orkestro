{% macro alert_forms(type="info", alert_base_class="", alert_message_class="") %}
    {% set base_classes = alert_base_class + " px-4 py-3 rounded relative mb-4 w-full hidden" %}
    {% if type == "success" %}
        {% set alert_classes = base_classes + " bg-green-100 border border-green-400 text-green-700" %}
    {% elif type == "error" %}
        {% set alert_classes = base_classes + " bg-red-100 border border-red-400 text-red-700" %}
    {% elif type == "warning" %}
        {% set alert_classes = base_classes + " bg-yellow-100 border border-yellow-400 text-yellow-700" %}
    {% else %}
        {% set alert_classes = base_classes + " bg-blue-100 border border-blue-400 text-blue-700" %}
    {% endif %}

    <div class="{{ alert_classes }}">
        <span class="{{ alert_message_class }}"></span>
    </div>
{% endmacro %}
