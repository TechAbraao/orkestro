<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Produtos | {% block title %} Default {% endblock title %}</title>

    {# Carregando as dependências (/libs) #}
    <script src="{{ url_for('static', filename='libs/tailwindcss.js') }}"></script>
    <script src="{{ url_for('static', filename='libs/jquery-3.7.1.min.js') }}"></script>

    <link rel="stylesheet" href="{{ url_for('static', filename='css/transitions.css') }}">

    {% block scripts %}
    {% endblock scripts %}

    {# Importing all macros #}
    {% import "macros/buttons.jinja2" as buttons %}
    {% import "macros/alerts.jinja2" as alerts %}
    {% import "macros/inputs.jinja2" as inputs %}
    {% import "macros/modals.jinja2" as modals %}
    {% import "macros/cards.jinja2" as cards %}
    {% import "macros/errors.jinja2" as errors %}
    {% import "macros/loaders.jinja2" as loaders %}
</head>
<body class="min-h-screen flex flex-col">
    {# Modals #}
    {{ modals.modal_contact_menu() }}


    {# Navbar #}
    <section class="text-white flex-shrink-0 bg-red-900 transition-all duration-300">
        {% block navbar %}

        {% endblock navbar %}
    </section>

    {# Menus #}
    <main class="flex items-center justify-center">
        {% block menu %}

        {% endblock menu %}
    </main>

    <section class="flex items-center justify-center">
        {% block cart %}
            {% include "partials/cart_navbar.jinja2" %}
        {% endblock cart %}
    </section>
    <script src="{{ url_for('static', filename='javascript/global_preLoader.js') }}"></script>
</body>
</html>